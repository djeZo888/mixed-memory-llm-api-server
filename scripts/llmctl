#!/usr/bin/env python3
"""M7B model/runtime manager.

This is a planning and validation tool only. Real model downloads, backend
installs, runtime activation, and API exposure are reserved for later
milestones.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
CONFIG_ROOT = Path(os.environ.get("LLMCTL_CONFIG_ROOT", REPO_ROOT / "configs"))
DATA_ROOT = Path(os.environ.get("LLMCTL_DATA_ROOT", "/data"))
MODELS_ROOT = DATA_ROOT / "models"
HF_CACHE_ROOT = DATA_ROOT / "hf-cache"
LOGS_ROOT = DATA_ROOT / "logs"
BUILD_ROOT = DATA_ROOT / "build"
SECRET_ROOT = DATA_ROOT / "services" / "secrets"
STATE_ROOT = Path(
    os.environ.get(
        "LLMCTL_STATE_DIR",
        str(DATA_ROOT / "services" / "llm-manager" / "state"),
    )
)
ACTIVE_ROOT = Path(
    os.environ.get(
        "LLMCTL_ACTIVE_DIR",
        str(DATA_ROOT / "services" / "llm-manager" / "active"),
    )
)
ACTIVE_FILE = ACTIVE_ROOT / "active.json"

REQUIRE_DATA = "scripts/common/require-data-mounted.sh"
ROOT_GUARD = "scripts/common/root-disk-guard.sh"
VERIFY_DOCKER = "scripts/docker/verify-docker-storage.sh"
VERIFY_GPU = "scripts/nvidia/verify-gpu-containers.sh"

MODEL_REQUIRED_FIELDS = {
    "name",
    "provider",
    "hf_repo",
    "family",
    "role",
    "model_type",
    "total_params",
    "active_params",
    "context_window",
    "license",
    "expected_precision",
    "expected_storage_gb",
    "expected_min_vram_gb",
    "expected_min_system_ram_gb",
    "recommended_runtimes",
    "preferred_runtime",
    "allowed_first_download",
    "notes",
    "source_urls",
}
RUNTIME_REQUIRED_FIELDS = {
    "name",
    "kind",
    "status",
    "openai_compatible",
    "localhost_bind_default",
    "gpu_required",
    "heterogeneous_ram_vram",
    "config_template",
    "healthcheck_path",
    "default_port",
    "risks",
    "source_urls",
}
ROLE_VALUES = {"smoke", "fast", "large", "research"}
MODEL_TYPE_VALUES = {"dense", "moe"}
RUNTIME_KIND_VALUES = {"docker", "native", "hybrid"}
RUNTIME_STATUS_VALUES = {"planned", "available", "experimental"}


class LlmctlError(Exception):
    pass


def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def parse_scalar(raw: str) -> Any:
    value = raw.strip()
    if value == "":
        return ""
    if (value.startswith('"') and value.endswith('"')) or (
        value.startswith("'") and value.endswith("'")
    ):
        return value[1:-1]
    lowered = value.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    if lowered in {"null", "none"}:
        return None
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [parse_scalar(part.strip()) for part in inner.split(",")]
    try:
        if value.isdigit() or (value.startswith("-") and value[1:].isdigit()):
            return int(value)
        if "." in value and all(ch.isdigit() or ch in ".-" for ch in value):
            return float(value)
    except ValueError:
        pass
    return value


def load_yaml(path: Path) -> dict[str, Any]:
    data: dict[str, Any] = {}
    current_list: str | None = None
    for line_no, raw_line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        if raw_line.startswith("  - "):
            if current_list is None:
                raise LlmctlError(f"{path}:{line_no}: list item without list key")
            data[current_list].append(parse_scalar(raw_line[4:].strip()))
            continue
        if raw_line.startswith(" "):
            raise LlmctlError(
                f"{path}:{line_no}: nested YAML is not supported by llmctl"
            )
        if ":" not in raw_line:
            raise LlmctlError(f"{path}:{line_no}: expected key: value")
        key, value = raw_line.split(":", 1)
        key = key.strip()
        if not key:
            raise LlmctlError(f"{path}:{line_no}: empty key")
        value = value.strip()
        if value == "":
            data[key] = []
            current_list = key
        else:
            data[key] = parse_scalar(value)
            current_list = None
    return data


def profile_dirs() -> tuple[Path, Path]:
    return CONFIG_ROOT / "models" / "profiles", CONFIG_ROOT / "runtimes"


def load_profiles() -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]]]:
    model_dir, runtime_dir = profile_dirs()
    models: dict[str, dict[str, Any]] = {}
    runtimes: dict[str, dict[str, Any]] = {}
    if not model_dir.exists():
        raise LlmctlError(f"model profile directory missing: {model_dir}")
    if not runtime_dir.exists():
        raise LlmctlError(f"runtime profile directory missing: {runtime_dir}")

    for path in sorted(model_dir.glob("*.yaml")):
        profile = load_yaml(path)
        profile["_path"] = str(path)
        name = str(profile.get("name", ""))
        if not name:
            raise LlmctlError(f"{path}: missing profile name")
        if name in models:
            raise LlmctlError(f"duplicate model profile name: {name}")
        models[name] = profile

    for path in sorted(runtime_dir.glob("*.yaml")):
        profile = load_yaml(path)
        profile["_path"] = str(path)
        name = str(profile.get("name", ""))
        if not name:
            raise LlmctlError(f"{path}: missing runtime name")
        if name in runtimes:
            raise LlmctlError(f"duplicate runtime profile name: {name}")
        runtimes[name] = profile

    return models, runtimes


def validate_model(name: str, profile: dict[str, Any], runtime_names: set[str]) -> list[str]:
    errors: list[str] = []
    missing = sorted(MODEL_REQUIRED_FIELDS - set(profile))
    if missing:
        errors.append(f"model {name}: missing fields: {', '.join(missing)}")
    if profile.get("role") not in ROLE_VALUES:
        errors.append(f"model {name}: invalid role {profile.get('role')!r}")
    if profile.get("model_type") not in MODEL_TYPE_VALUES:
        errors.append(f"model {name}: invalid model_type {profile.get('model_type')!r}")
    if not isinstance(profile.get("allowed_first_download"), bool):
        errors.append(f"model {name}: allowed_first_download must be true/false")
    recommended = profile.get("recommended_runtimes")
    if not isinstance(recommended, list) or not recommended:
        errors.append(f"model {name}: recommended_runtimes must be a non-empty list")
    else:
        unknown = sorted(set(str(item) for item in recommended) - runtime_names)
        if unknown:
            errors.append(
                f"model {name}: unknown recommended runtime(s): {', '.join(unknown)}"
            )
        preferred = profile.get("preferred_runtime")
        if preferred not in recommended:
            errors.append(
                f"model {name}: preferred_runtime must be in recommended_runtimes"
            )
    if not isinstance(profile.get("source_urls"), list) or not profile.get("source_urls"):
        errors.append(f"model {name}: source_urls must be a non-empty list")
    return errors


def validate_runtime(name: str, profile: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    missing = sorted(RUNTIME_REQUIRED_FIELDS - set(profile))
    if missing:
        errors.append(f"runtime {name}: missing fields: {', '.join(missing)}")
    if profile.get("kind") not in RUNTIME_KIND_VALUES:
        errors.append(f"runtime {name}: invalid kind {profile.get('kind')!r}")
    if profile.get("status") not in RUNTIME_STATUS_VALUES:
        errors.append(f"runtime {name}: invalid status {profile.get('status')!r}")
    for field in (
        "openai_compatible",
        "localhost_bind_default",
        "gpu_required",
        "heterogeneous_ram_vram",
    ):
        if not isinstance(profile.get(field), bool):
            errors.append(f"runtime {name}: {field} must be true/false")
    if not isinstance(profile.get("risks"), list) or not profile.get("risks"):
        errors.append(f"runtime {name}: risks must be a non-empty list")
    if not isinstance(profile.get("source_urls"), list) or not profile.get("source_urls"):
        errors.append(f"runtime {name}: source_urls must be a non-empty list")
    template = profile.get("config_template")
    if template and str(template) != "none":
        template_path = REPO_ROOT / str(template)
        if not template_path.exists():
            errors.append(f"runtime {name}: config_template missing: {template}")
    return errors


def validate_all() -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]], list[str]]:
    models, runtimes = load_profiles()
    runtime_names = set(runtimes)
    errors: list[str] = []
    for name, runtime in runtimes.items():
        errors.extend(validate_runtime(name, runtime))
    for name, model in models.items():
        errors.extend(validate_model(name, model, runtime_names))

    catalog_path = CONFIG_ROOT / "models" / "catalog.yaml"
    if catalog_path.exists():
        catalog = load_yaml(catalog_path)
        for key in ("model_profiles", "runtime_profiles"):
            if key not in catalog or not isinstance(catalog[key], list):
                errors.append(f"catalog: {key} must be a list")
        for name in catalog.get("model_profiles", []):
            if name not in models:
                errors.append(f"catalog: model profile not found: {name}")
        for name in catalog.get("runtime_profiles", []):
            if name not in runtimes:
                errors.append(f"catalog: runtime profile not found: {name}")
    else:
        errors.append(f"catalog missing: {catalog_path}")
    return models, runtimes, errors


def print_profile(profile: dict[str, Any]) -> None:
    for key in sorted(k for k in profile if not k.startswith("_")):
        value = profile[key]
        if isinstance(value, list):
            print(f"{key}:")
            for item in value:
                print(f"  - {item}")
        else:
            print(f"{key}: {value}")


def run_check(script: str, args: list[str] | None = None) -> None:
    args = args or []
    script_path = REPO_ROOT / script
    if not script_path.exists():
        raise LlmctlError(f"required check missing: {script}")
    subprocess.run([str(script_path), *args], cwd=REPO_ROOT, check=True)


def host_checks(level: str) -> None:
    if os.environ.get("LLMCTL_SKIP_HOST_CHECKS") == "1":
        print(f"SKIP: host checks skipped for fixture mode ({level})")
        return
    run_check(REQUIRE_DATA)
    run_check(ROOT_GUARD)
    if level in {"runtime", "doctor"}:
        run_check(VERIFY_DOCKER)
        run_check(VERIFY_GPU)


def cmd_doctor(_args: argparse.Namespace) -> int:
    _, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    host_checks("doctor")
    print("PASS: llmctl doctor completed")
    return 0


def cmd_list_models(_args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print("NAME\tROLE\tPREFERRED_RUNTIME\tALLOWED_FIRST_DOWNLOAD")
    for name in sorted(models):
        model = models[name]
        print(
            f"{name}\t{model.get('role')}\t{model.get('preferred_runtime')}\t"
            f"{str(model.get('allowed_first_download')).lower()}"
        )
    return 0


def cmd_list_runtimes(_args: argparse.Namespace) -> int:
    _, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print("NAME\tKIND\tSTATUS\tOPENAI_COMPATIBLE\tLOCALHOST_DEFAULT")
    for name in sorted(runtimes):
        runtime = runtimes[name]
        print(
            f"{name}\t{runtime.get('kind')}\t{runtime.get('status')}\t"
            f"{str(runtime.get('openai_compatible')).lower()}\t"
            f"{str(runtime.get('localhost_bind_default')).lower()}"
        )
    return 0


def cmd_show_model(args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.name not in models:
        eprint(f"FAIL: unknown model profile: {args.name}")
        return 1
    print_profile(models[args.name])
    return 0


def cmd_show_runtime(args: argparse.Namespace) -> int:
    _, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.name not in runtimes:
        eprint(f"FAIL: unknown runtime profile: {args.name}")
        return 1
    print_profile(runtimes[args.name])
    return 0


def cmd_validate(_args: argparse.Namespace) -> int:
    models, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print(f"PASS: validated {len(models)} model profile(s) and {len(runtimes)} runtime profile(s)")
    return 0


def load_active_state() -> tuple[Path, dict[str, Any]] | None:
    state_file = ACTIVE_FILE
    if not state_file.exists():
        legacy_file = STATE_ROOT / "active.json"
        if legacy_file.exists():
            state_file = legacy_file
        else:
            return None
    try:
        state = json.loads(state_file.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise LlmctlError(f"invalid active state file: {exc}")
    return state_file, state


def cmd_active(_args: argparse.Namespace) -> int:
    active = load_active_state()
    if active is None:
        print("active: none")
        return 0
    state_file, state = active
    print(f"active: {state.get('status', 'unknown')}")
    print(f"model_profile: {state.get('model_profile', state.get('model', 'unknown'))}")
    print(f"runtime_profile: {state.get('runtime_profile', state.get('runtime', 'unknown'))}")
    print(f"container_name: {state.get('container_name', 'unknown')}")
    print(f"bind: {state.get('bind', 'unknown')}")
    print(f"port: {state.get('port', 'unknown')}")
    print(f"endpoint: {state.get('endpoint', 'unknown')}")
    print(f"model_path: {state.get('model_path', 'unknown')}")
    print(f"image: {state.get('image', 'unknown')}")
    print(f"state_file: {state_file}")
    return 0


def cmd_status(_args: argparse.Namespace) -> int:
    active = load_active_state()
    if active is None:
        print("manager_status: planning_only")
    else:
        _, state = active
        print("manager_status: active")
        print(f"active_status: {state.get('status', 'unknown')}")
    print("runtime_state_dir:", STATE_ROOT)
    print("active_state_dir:", ACTIVE_ROOT)
    print("real_activation: available_for_m8b_smoke")
    return cmd_active(_args)


def plan_activation(model_name: str, runtime_name: str) -> int:
    models, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if model_name not in models:
        eprint(f"FAIL: unknown model profile: {model_name}")
        return 1
    if runtime_name not in runtimes:
        eprint(f"FAIL: unknown runtime profile: {runtime_name}")
        return 1
    model = models[model_name]
    runtime = runtimes[runtime_name]
    if runtime_name not in model.get("recommended_runtimes", []):
        eprint(
            "FAIL: runtime is not listed in model recommended_runtimes: "
            f"{runtime_name}"
        )
        return 1
    if not runtime.get("localhost_bind_default"):
        eprint("FAIL: selected runtime does not default to localhost binding")
        return 1
    host_checks("runtime")
    print("PLAN: activate model/runtime profile")
    print(f"model_profile: {model_name}")
    print(f"runtime_profile: {runtime_name}")
    print(f"hf_repo: {model.get('hf_repo')}")
    print(f"compose_template: {runtime.get('config_template')}")
    print("bind_host: 127.0.0.1")
    print(f"default_port: {runtime.get('default_port')}")
    print(f"models_mount: {MODELS_ROOT}:/data/models")
    print(f"hf_cache_mount: {HF_CACHE_ROOT}:/data/hf-cache")
    print(f"logs_mount: {LOGS_ROOT}:/data/logs")
    print(f"state_dir: {STATE_ROOT}")
    print("writes_planned: none in M7B")
    print("real_activation: reserved_for_later_milestones")
    return 0


def cmd_plan_activate(args: argparse.Namespace) -> int:
    return plan_activation(args.model_profile, args.runtime)


def cmd_activate(args: argparse.Namespace) -> int:
    if not args.dry_run:
        eprint("STOP: activate requires --dry-run in M7B; real activation is reserved")
        return 2
    result = plan_activation(args.model_profile, args.runtime)
    if result == 0:
        print("DRY-RUN: no runtime started and no state was written")
    return result


def cmd_deactivate(args: argparse.Namespace) -> int:
    if not args.dry_run:
        eprint("STOP: deactivate requires --dry-run in M7B; real deactivation is reserved")
        return 2
    active = load_active_state()
    print("DRY-RUN: would stop the active runtime and clear active state")
    if active is not None:
        _, state = active
        compose_file = state.get("compose_file", "unknown")
        container_name = state.get("container_name", "unknown")
        print(f"container_name: {container_name}")
        print(f"compose_file: {compose_file}")
        print(f"stop_command: sudo -n docker compose -f {compose_file} --profile sglang-smoke down")
    print(f"state_dir: {STATE_ROOT}")
    print(f"active_state_dir: {ACTIVE_ROOT}")
    print("writes_planned: none in dry-run")
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    if not args.dry_run:
        eprint("STOP: logs requires --dry-run in M7B")
        return 2
    active = load_active_state()
    print("DRY-RUN: would inspect manager/runtime logs")
    print(f"logs_root: {LOGS_ROOT}")
    if active is not None:
        _, state = active
        container_name = state.get("container_name", "unknown")
        print(f"container_name: {container_name}")
        print(f"log_command: sudo -n docker logs --tail 200 {container_name}")
    else:
        print("active: none")
    print("no log files were read")
    return 0


def cmd_plan_download(args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.model_profile not in models:
        eprint(f"FAIL: unknown model profile: {args.model_profile}")
        return 1
    model = models[args.model_profile]
    if not model.get("allowed_first_download"):
        eprint(
            "STOP: this profile is not approved for first download; human approval "
            "is required"
        )
        return 2
    host_checks("download")
    print("PLAN: download model profile")
    print(f"model_profile: {args.model_profile}")
    print(f"hf_repo: {model.get('hf_repo')}")
    print(f"target_root: {MODELS_ROOT}")
    print(f"hf_cache_root: {HF_CACHE_ROOT}")
    print("download_performed: false")
    print("real_download: reserved_for_M8_or_later")
    return 0


def cmd_env(_args: argparse.Namespace) -> int:
    print(f"CONFIG_ROOT={CONFIG_ROOT}")
    print(f"DATA_ROOT={DATA_ROOT}")
    print(f"MODELS_ROOT={MODELS_ROOT}")
    print(f"HF_HOME={HF_CACHE_ROOT}")
    print(f"HF_HUB_CACHE={HF_CACHE_ROOT / 'hub'}")
    print(f"TRANSFORMERS_CACHE={HF_CACHE_ROOT / 'transformers'}")
    print(f"LOGS_ROOT={LOGS_ROOT}")
    print(f"BUILD_ROOT={BUILD_ROOT}")
    print(f"STATE_ROOT={STATE_ROOT}")
    print(f"ACTIVE_ROOT={ACTIVE_ROOT}")
    print(f"SECRET_ROOT={SECRET_ROOT}")
    print("SECRET_VALUES=not_read")
    return 0


def unsupported_real_command(command: str) -> int:
    eprint(
        f"STOP: {command} is reserved for later milestones; use plan-* or --dry-run "
        "commands in M7B"
    )
    return 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="llmctl",
        description="Validate and plan model/runtime profiles. M7B is dry-run only.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("doctor").set_defaults(func=cmd_doctor)
    subparsers.add_parser("list-models").set_defaults(func=cmd_list_models)
    subparsers.add_parser("list-runtimes").set_defaults(func=cmd_list_runtimes)
    subparsers.add_parser("validate").set_defaults(func=cmd_validate)
    subparsers.add_parser("active").set_defaults(func=cmd_active)
    subparsers.add_parser("status").set_defaults(func=cmd_status)
    subparsers.add_parser("env").set_defaults(func=cmd_env)

    show_model = subparsers.add_parser("show-model")
    show_model.add_argument("name")
    show_model.set_defaults(func=cmd_show_model)

    show_runtime = subparsers.add_parser("show-runtime")
    show_runtime.add_argument("name")
    show_runtime.set_defaults(func=cmd_show_runtime)

    plan_activate = subparsers.add_parser("plan-activate")
    plan_activate.add_argument("model_profile")
    plan_activate.add_argument("--runtime", required=True)
    plan_activate.set_defaults(func=cmd_plan_activate)

    activate = subparsers.add_parser("activate")
    activate.add_argument("model_profile")
    activate.add_argument("--runtime", required=True)
    activate.add_argument("--dry-run", action="store_true")
    activate.set_defaults(func=cmd_activate)

    deactivate = subparsers.add_parser("deactivate")
    deactivate.add_argument("--dry-run", action="store_true")
    deactivate.set_defaults(func=cmd_deactivate)

    logs = subparsers.add_parser("logs")
    logs.add_argument("--dry-run", action="store_true")
    logs.set_defaults(func=cmd_logs)

    plan_download = subparsers.add_parser("plan-download")
    plan_download.add_argument("model_profile")
    plan_download.set_defaults(func=cmd_plan_download)

    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if argv and argv[0] in {"download", "start", "stop", "restart"}:
        return unsupported_real_command(argv[0])
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except subprocess.CalledProcessError as exc:
        eprint(f"FAIL: required check failed: {' '.join(map(str, exc.cmd))}")
        return exc.returncode or 1
    except LlmctlError as exc:
        eprint(f"FAIL: {exc}")
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
