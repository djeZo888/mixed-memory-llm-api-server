    "name",
    "provider",
    "hf_repo",
    "family",
    "role",
    "model_type",
    "total_params",
    "active_params",
    "context_window",
    "license",
    "expected_precision",
    "expected_storage_gb",
    "expected_min_vram_gb",
    "expected_min_system_ram_gb",
    "recommended_runtimes",
    "preferred_runtime",
    "allowed_first_download",
    "notes",
    "source_urls",
}
RUNTIME_REQUIRED_FIELDS = {
    "name",
    "kind",
    "status",
    "openai_compatible",
    "localhost_bind_default",
    "gpu_required",
    "heterogeneous_ram_vram",
    "config_template",
    "healthcheck_path",
    "default_port",
    "risks",
    "source_urls",
}
ROLE_VALUES = {"smoke", "fast", "large", "research"}
MODEL_TYPE_VALUES = {"dense", "moe"}
RUNTIME_KIND_VALUES = {"docker", "native", "hybrid"}
RUNTIME_STATUS_VALUES = {"planned", "available", "experimental"}


class LlmctlError(Exception):
    pass


def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def parse_scalar(raw: str) -> Any:
    value = raw.strip()
    if value == "":
        return ""
    if (value.startswith('"') and value.endswith('"')) or (
        value.startswith("'") and value.endswith("'")
    ):
        return value[1:-1]
    lowered = value.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    if lowered in {"null", "none"}:
        return None
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [parse_scalar(part.strip()) for part in inner.split(",")]
    try:
        if value.isdigit() or (value.startswith("-") and value[1:].isdigit()):
            return int(value)
        if "." in value and all(ch.isdigit() or ch in ".-" for ch in value):
            return float(value)
    except ValueError:
        pass
    return value


def load_yaml(path: Path) -> dict[str, Any]:
    data: dict[str, Any] = {}
    current_list: str | None = None
    for line_no, raw_line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        if raw_line.startswith("  - "):
            if current_list is None:
                raise LlmctlError(f"{path}:{line_no}: list item without list key")
            data[current_list].append(parse_scalar(raw_line[4:].strip()))
            continue
        if raw_line.startswith(" "):
            raise LlmctlError(
                f"{path}:{line_no}: nested YAML is not supported by llmctl"
            )
        if ":" not in raw_line:
            raise LlmctlError(f"{path}:{line_no}: expected key: value")
        key, value = raw_line.split(":", 1)
        key = key.strip()
        if not key:
            raise LlmctlError(f"{path}:{line_no}: empty key")
        value = value.strip()
        if value == "":
            data[key] = []
            current_list = key
        else:
            data[key] = parse_scalar(value)
            current_list = None
    return data


def profile_dirs() -> tuple[Path, Path]:
    return CONFIG_ROOT / "models" / "profiles", CONFIG_ROOT / "runtimes"


def load_profiles() -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]]]:
    model_dir, runtime_dir = profile_dirs()
    models: dict[str, dict[str, Any]] = {}
    runtimes: dict[str, dict[str, Any]] = {}
    if not model_dir.exists():
        raise LlmctlError(f"model profile directory missing: {model_dir}")
    if not runtime_dir.exists():
        raise LlmctlError(f"runtime profile directory missing: {runtime_dir}")

    for path in sorted(model_dir.glob("*.yaml")):
        profile = load_yaml(path)
        profile["_path"] = str(path)
        name = str(profile.get("name", ""))
        if not name:
            raise LlmctlError(f"{path}: missing profile name")
        if name in models:
            raise LlmctlError(f"duplicate model profile name: {name}")
        models[name] = profile

    for path in sorted(runtime_dir.glob("*.yaml")):
        profile = load_yaml(path)
        profile["_path"] = str(path)
        name = str(profile.get("name", ""))
        if not name:
            raise LlmctlError(f"{path}: missing runtime name")
        if name in runtimes:
            raise LlmctlError(f"duplicate runtime profile name: {name}")
        runtimes[name] = profile

    return models, runtimes


def validate_model(name: str, profile: dict[str, Any], runtime_names: set[str]) -> list[str]:
    errors: list[str] = []
    missing = sorted(MODEL_REQUIRED_FIELDS - set(profile))
    if missing:
        errors.append(f"model {name}: missing fields: {', '.join(missing)}")
    if profile.get("role") not in ROLE_VALUES:
        errors.append(f"model {name}: invalid role {profile.get('role')!r}")
    if profile.get("model_type") not in MODEL_TYPE_VALUES:
        errors.append(f"model {name}: invalid model_type {profile.get('model_type')!r}")
    if not isinstance(profile.get("allowed_first_download"), bool):
        errors.append(f"model {name}: allowed_first_download must be true/false")
    recommended = profile.get("recommended_runtimes")
    if not isinstance(recommended, list) or not recommended:
        errors.append(f"model {name}: recommended_runtimes must be a non-empty list")
    else:
        unknown = sorted(set(str(item) for item in recommended) - runtime_names)
        if unknown:
            errors.append(
                f"model {name}: unknown recommended runtime(s): {', '.join(unknown)}"
            )
        preferred = profile.get("preferred_runtime")
        if preferred not in recommended:
            errors.append(
                f"model {name}: preferred_runtime must be in recommended_runtimes"
            )
    if not isinstance(profile.get("source_urls"), list) or not profile.get("source_urls"):
        errors.append(f"model {name}: source_urls must be a non-empty list")
    return errors


def validate_runtime(name: str, profile: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    missing = sorted(RUNTIME_REQUIRED_FIELDS - set(profile))
    if missing:
        errors.append(f"runtime {name}: missing fields: {', '.join(missing)}")
    if profile.get("kind") not in RUNTIME_KIND_VALUES:
        errors.append(f"runtime {name}: invalid kind {profile.get('kind')!r}")
    if profile.get("status") not in RUNTIME_STATUS_VALUES:
        errors.append(f"runtime {name}: invalid status {profile.get('status')!r}")
    for field in (
        "openai_compatible",
        "localhost_bind_default",
        "gpu_required",
        "heterogeneous_ram_vram",
    ):
        if not isinstance(profile.get(field), bool):
            errors.append(f"runtime {name}: {field} must be true/false")
    if not isinstance(profile.get("risks"), list) or not profile.get("risks"):
        errors.append(f"runtime {name}: risks must be a non-empty list")
    if not isinstance(profile.get("source_urls"), list) or not profile.get("source_urls"):
        errors.append(f"runtime {name}: source_urls must be a non-empty list")
    template = profile.get("config_template")
    if template and str(template) != "none":
        template_path = REPO_ROOT / str(template)
        if not template_path.exists():
            errors.append(f"runtime {name}: config_template missing: {template}")
    return errors


def validate_all() -> tuple[dict[str, dict[str, Any]], dict[str, dict[str, Any]], list[str]]:
    models, runtimes = load_profiles()
    runtime_names = set(runtimes)
    errors: list[str] = []
    for name, runtime in runtimes.items():
        errors.extend(validate_runtime(name, runtime))
    for name, model in models.items():
        errors.extend(validate_model(name, model, runtime_names))

    catalog_path = CONFIG_ROOT / "models" / "catalog.yaml"
    if catalog_path.exists():
        catalog = load_yaml(catalog_path)
        for key in ("model_profiles", "runtime_profiles"):
            if key not in catalog or not isinstance(catalog[key], list):
                errors.append(f"catalog: {key} must be a list")
        for name in catalog.get("model_profiles", []):
            if name not in models:
                errors.append(f"catalog: model profile not found: {name}")
        for name in catalog.get("runtime_profiles", []):
            if name not in runtimes:
                errors.append(f"catalog: runtime profile not found: {name}")
    else:
        errors.append(f"catalog missing: {catalog_path}")
    return models, runtimes, errors


def print_profile(profile: dict[str, Any]) -> None:
    for key in sorted(k for k in profile if not k.startswith("_")):
        value = profile[key]
        if isinstance(value, list):
            print(f"{key}:")
            for item in value:
                print(f"  - {item}")
        else:
            print(f"{key}: {value}")


def run_check(script: str, args: list[str] | None = None) -> None:
    args = args or []
    script_path = REPO_ROOT / script
    if not script_path.exists():
        raise LlmctlError(f"required check missing: {script}")
    subprocess.run([str(script_path), *args], cwd=REPO_ROOT, check=True)


def host_checks(level: str) -> None:
    if os.environ.get("LLMCTL_SKIP_HOST_CHECKS") == "1":
        print(f"SKIP: host checks skipped for fixture mode ({level})")
        return
    run_check(REQUIRE_DATA)
    run_check(ROOT_GUARD)
    if level in {"runtime", "doctor"}:
        run_check(VERIFY_DOCKER)
        run_check(VERIFY_GPU)


def cmd_doctor(_args: argparse.Namespace) -> int:
    _, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    host_checks("doctor")
    print("PASS: llmctl doctor completed")
    return 0


def cmd_list_models(_args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print("NAME\tROLE\tPREFERRED_RUNTIME\tALLOWED_FIRST_DOWNLOAD")
    for name in sorted(models):
        model = models[name]
        print(
            f"{name}\t{model.get('role')}\t{model.get('preferred_runtime')}\t"
            f"{str(model.get('allowed_first_download')).lower()}"
        )
    return 0


def cmd_list_runtimes(_args: argparse.Namespace) -> int:
    _, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print("NAME\tKIND\tSTATUS\tOPENAI_COMPATIBLE\tLOCALHOST_DEFAULT")
    for name in sorted(runtimes):
        runtime = runtimes[name]
        print(
            f"{name}\t{runtime.get('kind')}\t{runtime.get('status')}\t"
            f"{str(runtime.get('openai_compatible')).lower()}\t"
            f"{str(runtime.get('localhost_bind_default')).lower()}"
        )
    return 0


def cmd_show_model(args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.name not in models:
        eprint(f"FAIL: unknown model profile: {args.name}")
        return 1
    print_profile(models[args.name])
    return 0


def cmd_show_runtime(args: argparse.Namespace) -> int:
    _, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.name not in runtimes:
        eprint(f"FAIL: unknown runtime profile: {args.name}")
        return 1
    print_profile(runtimes[args.name])
    return 0


def cmd_validate(_args: argparse.Namespace) -> int:
    models, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    print(f"PASS: validated {len(models)} model profile(s) and {len(runtimes)} runtime profile(s)")
    return 0


def load_active_state() -> tuple[Path, dict[str, Any]] | None:
    state_file = ACTIVE_FILE
    if not state_file.exists():
        legacy_file = STATE_ROOT / "active.json"
        if legacy_file.exists():
            state_file = legacy_file
        else:
            return None
    try:
        state = json.loads(state_file.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise LlmctlError(f"invalid active state file: {exc}")
    return state_file, state


def utc_timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def compact_timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")


def skip_docker() -> bool:
    return os.environ.get("LLMCTL_SKIP_DOCKER") == "1"


def run_capture(cmd: list[str], check: bool = True, timeout: int | None = None) -> str:
    result = subprocess.run(
        cmd,
        cwd=REPO_ROOT,
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=timeout,
    )
    return result.stdout.strip()


def run_passthrough(cmd: list[str], check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=REPO_ROOT, check=check, text=True)


def docker_cmd(*args: str) -> list[str]:
    return ["sudo", "-n", "docker", *args]


def compose_cmd(compose_file: Path, *args: str, profile: str | None = SMOKE_COMPOSE_PROFILE) -> list[str]:
    cmd = docker_cmd("compose", "-f", str(compose_file))
    if profile:
        cmd.extend(["--profile", profile])
    cmd.extend(args)
    return cmd


def docker_root_dir() -> str:
    if skip_docker():
        return os.environ.get("LLMCTL_FAKE_DOCKER_ROOT_DIR", "/data/docker")
    return run_capture(docker_cmd("info", "--format", "{{.DockerRootDir}}"))


def ensure_docker_root_dir() -> None:
    root_dir = docker_root_dir()
    if root_dir != "/data/docker":
        raise LlmctlError(f"Docker Root Dir must be /data/docker, got: {root_dir}")


def lifecycle_host_checks(require_gpu: bool = False) -> None:
    if os.environ.get("LLMCTL_SKIP_HOST_CHECKS") == "1":
        print("SKIP: host checks skipped for fixture mode")
        return
    run_check(REQUIRE_DATA)
    run_check(ROOT_GUARD)
    run_check(VERIFY_DOCKER)
    ensure_docker_root_dir()
    if require_gpu:
        run_check(VERIFY_GPU)


def smoke_state_template(status: str = "stopped") -> dict[str, Any]:
    return {
        "model_profile": SMOKE_MODEL_PROFILE,
        "runtime_profile": SMOKE_RUNTIME_PROFILE,
        "compose_file": str(SMOKE_COMPOSE_FILE),
        "container_name": SMOKE_CONTAINER_NAME,
        "bind": SMOKE_BIND,
        "port": SMOKE_PORT,
        "endpoint": SMOKE_ENDPOINT,
        "model_path": str(SMOKE_MODEL_PATH),
        "image": SMOKE_IMAGE,
        "status": status,
    }


def require_active_state() -> tuple[Path, dict[str, Any]]:
    active = load_active_state()
    if active is None:
        raise LlmctlError(
            f"active state missing: {ACTIVE_FILE}; no managed deployment is selected"
        )
    state_file, state = active
    validate_supported_state(state)
    return state_file, state


def state_for_start() -> tuple[Path | None, dict[str, Any]]:
    active = load_active_state()
    if active is None:
        state = smoke_state_template("stopped")
        print("INFO: active.json missing; using managed smoke compose fallback")
        return None, state
    state_file, state = active
    validate_supported_state(state)
    return state_file, state


def expected_deployment(state: dict[str, Any]) -> dict[str, Any]:
    model_profile = state.get("model_profile")
    if model_profile == SMOKE_MODEL_PROFILE:
        return {
            "model_profile": SMOKE_MODEL_PROFILE,
            "runtime_profile": SMOKE_RUNTIME_PROFILE,
            "container_name": SMOKE_CONTAINER_NAME,
            "bind": SMOKE_BIND,
            "port": SMOKE_PORT,
            "container_port": SMOKE_PORT,
            "endpoint": SMOKE_ENDPOINT,
            "model_path": str(SMOKE_MODEL_PATH),
            "image": SMOKE_IMAGE,
            "compose_file": str(SMOKE_COMPOSE_FILE),
            "compose_profile": SMOKE_COMPOSE_PROFILE,
            "served_model_name": SMOKE_MODEL_PROFILE,
            "label": "M8B SGLang smoke deployment",
        }
    if model_profile == REAL_MODEL_PROFILE:
        return {
            "model_profile": REAL_MODEL_PROFILE,
            "runtime_profile": REAL_RUNTIME_PROFILE,
            "container_name": REAL_CONTAINER_NAME,
            "bind": REAL_BIND,
            "port": REAL_PORT,
            "container_port": REAL_CONTAINER_PORT,
            "endpoint": REAL_ENDPOINT,
            "model_path": str(REAL_MODEL_PATH),
            "image": REAL_IMAGE,
            "compose_file": str(REAL_COMPOSE_FILE),
            "compose_profile": "",
            "served_model_name": REAL_MODEL_PROFILE,
            "label": "M9B SGLang real fast deployment",
        }
    raise LlmctlError(
        "active state is not a supported SGLang deployment: "
        f"model_profile={model_profile!r}"
    )


def validate_supported_state(state: dict[str, Any]) -> None:
    expected = expected_deployment(state)
    for key in (
        "model_profile",
        "runtime_profile",
        "container_name",
        "bind",
        "port",
        "endpoint",
        "model_path",
        "image",
    ):
        if state.get(key) != expected[key]:
            raise LlmctlError(
                "active state does not match supported deployment "
                f"{expected['model_profile']}: {key}={state.get(key)!r}"
            )
    if state.get("compose_file") and str(state.get("compose_file")) != expected["compose_file"]:
        raise LlmctlError(
            f"active state compose_file is not expected for {expected['model_profile']}: "
            f"{state.get('compose_file')!r}"
        )


def validate_smoke_state(state: dict[str, Any]) -> None:
    validate_supported_state(state)
    if state.get("model_profile") != SMOKE_MODEL_PROFILE:
        raise LlmctlError(
            "active state is not the M8B smoke deployment: "
            f"model_profile={state.get('model_profile')!r}"
        )


def state_compose_profile(state: dict[str, Any]) -> str | None:
    if "compose_profile" in state:
        value = state.get("compose_profile")
        return str(value) if value else None
    return expected_deployment(state)["compose_profile"] or None


def state_compose_file(state: dict[str, Any]) -> Path:
    compose_file = Path(str(state.get("compose_file") or SMOKE_COMPOSE_FILE))
    if not compose_file.exists():
        raise LlmctlError(f"compose file missing: {compose_file}")
    return compose_file


def compose_config_text(
    compose_file: Path, profile: str | None = SMOKE_COMPOSE_PROFILE
) -> str:
    if skip_docker():
        return compose_file.read_text(encoding="utf-8")
    return run_capture(compose_cmd(compose_file, "config", profile=profile))


def ensure_localhost_compose_bind(compose_file: Path, state: dict[str, Any]) -> None:
    expected = expected_deployment(state)
    port = int(state.get("port", expected["port"]))
    container_port = int(expected["container_port"])
    raw = compose_file.read_text(encoding="utf-8")
    public_binds = (
        f"0.0.0.0:{port}:{container_port}",
        f"[::]:{port}:{container_port}",
        f"0.0.0.0:{port}:",
        f"[::]:{port}:",
    )
    if any(bind in raw for bind in public_binds):
        raise LlmctlError("public host bind detected in compose file")
    rendered = compose_config_text(compose_file, state_compose_profile(state))
    if "host_ip: 0.0.0.0" in rendered or "host_ip: '0.0.0.0'" in rendered:
        raise LlmctlError("public host bind detected in rendered compose config")
    if "host_ip: \"0.0.0.0\"" in rendered or "host_ip: ::" in rendered:
        raise LlmctlError("public host bind detected in rendered compose config")
    raw_bind = f"127.0.0.1:{port}:{container_port}"
    if raw_bind not in raw and "host_ip: 127.0.0.1" not in rendered:
        raise LlmctlError(f"localhost-only 127.0.0.1:{port} bind was not found")


def container_status(container_name: str) -> tuple[str, str]:
    if skip_docker():
        return (
            os.environ.get("LLMCTL_FAKE_CONTAINER_STATUS", "missing"),
            os.environ.get("LLMCTL_FAKE_CONTAINER_HEALTH", ""),
        )
    try:
        raw = run_capture(
            docker_cmd(
                "inspect",
                "-f",
                "{{.State.Status}}|{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}",
                container_name,
            ),
            check=True,
        )
    except subprocess.CalledProcessError:
        return "missing", ""
    status, _, health = raw.partition("|")
    return status or "unknown", health or "none"


def port_lines() -> str:
    if skip_docker():
        return os.environ.get("LLMCTL_FAKE_PORT_LINES", "")
    try:
        return run_capture(["ss", "-H", "-ltnp"], check=True)
    except subprocess.CalledProcessError:
        return ""


def port_lines_for(port: int) -> list[str]:
    needle = f":{port}"
    return [line for line in port_lines().splitlines() if needle in line]


def port_30000_lines() -> list[str]:
    return port_lines_for(30000)


def endpoint_models_ok(endpoint: str, expected_model: str = SMOKE_MODEL_PROFILE) -> bool:
    if skip_docker():
        return os.environ.get("LLMCTL_FAKE_ENDPOINT_OK") == "1"
    try:
        output = run_capture(
            ["curl", "-fsS", "--max-time", "5", f"{endpoint}/models"],
            check=True,
            timeout=8,
        )
        data = json.loads(output)
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return False
    model_ids = [item.get("id") for item in data.get("data", [])]
    return expected_model in model_ids


def localhost_bind_ok(lines: list[str], port: int = 30000) -> bool:
    if not lines:
        return False
    joined = "\n".join(lines)
    if f"0.0.0.0:{port}" in joined or f"[::]:{port}" in joined:
        return False
    return f"127.0.0.1:{port}" in joined


def inspect_live_state(state: dict[str, Any]) -> dict[str, Any]:
    expected = expected_deployment(state)
    container_name = str(state.get("container_name", expected["container_name"]))
    endpoint = str(state.get("endpoint", expected["endpoint"]))
    port = int(state.get("port", expected["port"]))
    expected_model = str(state.get("served_model_name", expected["served_model_name"]))
    live_status, live_health = container_status(container_name)
    listeners = port_lines_for(port)
    return {
        "status": live_status,
        "health": live_health,
        "port": port,
        "listeners": listeners,
        "port_listening": bool(listeners),
        "localhost_bind": localhost_bind_ok(listeners, port) if listeners else False,
        "endpoint_ok": endpoint_models_ok(endpoint, expected_model),
    }


def classify_manager_status(state: dict[str, Any], live: dict[str, Any]) -> str:
    configured = str(state.get("status", "unknown"))
    live_status = str(live["status"])
    health = str(live["health"] or "none")
    if configured == "stopped":
        if live_status == "running" or live["port_listening"]:
            return "stale"
        return "stopped"
    if configured != "active":
        return configured
    if live_status != "running":
        return "stale"
    if live["port_listening"] and not live["localhost_bind"]:
        return "stale"
    if health == "unhealthy":
        return "unhealthy"
    if health == "starting":
        return "starting"
    if not live["port_listening"]:
        return "starting"
    if health in {"healthy", "none", ""} and live["endpoint_ok"]:
        return "active"
    if health == "healthy" and not live["endpoint_ok"]:
        return "unhealthy"
    return "starting"


def live_state_messages(
    state: dict[str, Any], live: dict[str, Any], manager_status: str
) -> list[str]:
    configured = str(state.get("status", "unknown"))
    live_status = str(live["status"])
    health = str(live["health"] or "none")
    port = int(live["port"])
    messages: list[str] = []
    if configured == "active" and manager_status == "stale":
        if live_status != "running":
            messages.append(
                f"active_state_stale: active.json says active but container is {live_status}"
            )
        if live["port_listening"] and not live["localhost_bind"]:
            messages.append(f"active_state_stale: port {port} is not localhost-only")
    elif configured == "active" and manager_status == "starting":
        if health == "starting":
            messages.append("active_state_starting: Docker health is still starting")
        if not live["port_listening"]:
            messages.append(f"active_state_starting: port {port} is not listening yet")
        if live["port_listening"] and not live["endpoint_ok"]:
            messages.append("active_state_starting: endpoint /v1/models is not ready yet")
    elif configured == "active" and manager_status == "unhealthy":
        if health == "unhealthy":
            messages.append("active_state_unhealthy: Docker health is unhealthy")
        elif not live["endpoint_ok"]:
            messages.append("active_state_unhealthy: endpoint /v1/models is not healthy")
    elif configured == "stopped" and manager_status == "stale":
        if live_status == "running":
            messages.append("active_state_stale: active.json says stopped but container is running")
        if live["port_listening"]:
            messages.append(
                f"active_state_stale: active.json says stopped but port {port} is listening"
            )
    return messages


def state_live_report(state: dict[str, Any]) -> tuple[str, list[str]]:
    live = inspect_live_state(state)
    manager_status = classify_manager_status(state, live)
    print(f"live_container_status: {live['status']}")
    if live["health"]:
        print(f"live_container_health: {live['health']}")
    print(f"live_port_{live['port']}: {'listening' if live['port_listening'] else 'not_listening'}")
    print(f"live_endpoint_models: {'ok' if live['endpoint_ok'] else 'not_ok'}")
    return manager_status, live_state_messages(state, live, manager_status)


def print_active_state(
    state_file: Path,
    state: dict[str, Any],
    *,
    include_live: bool = True,
    warnings: list[str] | None = None,
) -> int:
    print(f"active: {state.get('status', 'unknown')}")
    print(f"model_profile: {state.get('model_profile', state.get('model', 'unknown'))}")
    print(f"runtime_profile: {state.get('runtime_profile', state.get('runtime', 'unknown'))}")
    print(f"container_name: {state.get('container_name', 'unknown')}")
    print(f"bind: {state.get('bind', 'unknown')}")
    print(f"port: {state.get('port', 'unknown')}")
    print(f"endpoint: {state.get('endpoint', 'unknown')}")
    print(f"model_path: {state.get('model_path', 'unknown')}")
    print(f"image: {state.get('image', 'unknown')}")
    print(f"state_file: {state_file}")
    if include_live:
        _, warnings = state_live_report(state)
    elif warnings is None:
        warnings = []
    for warning in warnings:
        print(f"WARN: {warning}")
    return 0


def cmd_active(_args: argparse.Namespace) -> int:
    active = load_active_state()
    if active is None:
        print("active: none")
        return 0
    state_file, state = active
    return print_active_state(state_file, state)


def cmd_status(_args: argparse.Namespace) -> int:
    active = load_active_state()
    if active is None:
        print("manager_status: planning_only")
        print("active: none")
        print("runtime_state_dir:", STATE_ROOT)
        print("active_state_dir:", ACTIVE_ROOT)
        print("real_activation: available_for_m8b_smoke")
        return 0
    else:
        state_file, state = active
        manager_status, warnings = state_live_report(state)
        print(f"manager_status: {manager_status}")
        print(f"active_status: {state.get('status', 'unknown')}")
        print("runtime_state_dir:", STATE_ROOT)
        print("active_state_dir:", ACTIVE_ROOT)
        activation = "active_m9b_real_fast" if state.get("model_profile") == REAL_MODEL_PROFILE else "available_for_m8b_smoke"
        print(f"real_activation: {activation}")
        for warning in warnings:
            print(f"WARN: {warning}")
        return print_active_state(state_file, state, include_live=False, warnings=warnings)


def plan_activation(model_name: str, runtime_name: str) -> int:
    models, runtimes, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if model_name not in models:
        eprint(f"FAIL: unknown model profile: {model_name}")
        return 1
    if runtime_name not in runtimes:
        eprint(f"FAIL: unknown runtime profile: {runtime_name}")
        return 1
    model = models[model_name]
    runtime = runtimes[runtime_name]
    if runtime_name not in model.get("recommended_runtimes", []):
        eprint(
            "FAIL: runtime is not listed in model recommended_runtimes: "
            f"{runtime_name}"
        )
        return 1
    if not runtime.get("localhost_bind_default"):
        eprint("FAIL: selected runtime does not default to localhost binding")
        return 1
    host_checks("runtime")
    print("PLAN: activate model/runtime profile")
    print(f"model_profile: {model_name}")
    print(f"runtime_profile: {runtime_name}")
    print(f"hf_repo: {model.get('hf_repo')}")
    print(f"compose_template: {runtime.get('config_template')}")
    print("bind_host: 127.0.0.1")
    print(f"default_port: {runtime.get('default_port')}")
    print(f"models_mount: {MODELS_ROOT}:/data/models")
    print(f"hf_cache_mount: {HF_CACHE_ROOT}:/data/hf-cache")
    print(f"logs_mount: {LOGS_ROOT}:/data/logs")
    print(f"state_dir: {STATE_ROOT}")
    print("writes_planned: none for plan-activate")
    print("real_activation: reserved_for_later_milestones")
    return 0


def cmd_plan_activate(args: argparse.Namespace) -> int:
    return plan_activation(args.model_profile, args.runtime)


def cmd_activate(args: argparse.Namespace) -> int:
    if not args.dry_run:
        eprint(
            "STOP: activate for new model/runtime pairs is reserved; use --dry-run "
            "or use start --yes for the active managed deployment"
        )
        return 2
    result = plan_activation(args.model_profile, args.runtime)
    if result == 0:
        print("DRY-RUN: no runtime started and no state was written")
    return result


def require_yes(args: argparse.Namespace, command: str) -> bool:
    if args.dry_run:
        return False
    if args.yes:
        return True
    eprint(f"STOP: {command} is mutating and requires --yes")
    eprint(f"dry_run_command: scripts/llmctl {command} --dry-run")
    return False


def write_active_state(state: dict[str, Any]) -> None:
    ACTIVE_ROOT.mkdir(parents=True, exist_ok=True)
    tmp = ACTIVE_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(ACTIVE_FILE)


def update_active_state(state: dict[str, Any], **updates: Any) -> dict[str, Any]:
    merged = dict(state)
    merged.update(updates)
    merged["last_checked_at"] = utc_timestamp()
    write_active_state(merged)
    return merged


def ensure_model_files_exist(state: dict[str, Any]) -> None:
    expected = expected_deployment(state)
    model_path = Path(str(state.get("model_path", expected["model_path"])))
    if not model_path.is_dir():
        raise LlmctlError(f"model path missing: {model_path}")
    if not (model_path / "config.json").is_file():
        raise LlmctlError(f"model config missing under: {model_path}")


def ensure_port_available_for_start(state: dict[str, Any]) -> None:
    expected = expected_deployment(state)
    port = int(state.get("port", expected["port"]))
    container_name = str(state.get("container_name", expected["container_name"]))
    listeners = port_lines_for(port)
    if not listeners:
        return
    live_status, _ = container_status(container_name)
    if live_status == "running" and localhost_bind_ok(listeners, port):
        return
    raise LlmctlError(
        f"port {port} is occupied by an unknown or non-localhost listener: "
        + " | ".join(listeners)
    )


def ensure_lifecycle_preflight(
    state: dict[str, Any],
    *,
    require_gpu: bool,
    check_port: bool,
) -> Path:
    lifecycle_host_checks(require_gpu=require_gpu)
    validate_supported_state(state)
    compose_file = state_compose_file(state)
    ensure_localhost_compose_bind(compose_file, state)
    if check_port:
        ensure_port_available_for_start(state)
    return compose_file


def wait_for_stopped(container_name: str, port: int = 30000, timeout_seconds: int = 90) -> None:
    if skip_docker():
        return
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        live_status, _ = container_status(container_name)
        if live_status != "running" and not port_lines_for(port):
            return
        time.sleep(2)
    raise LlmctlError(f"container did not stop cleanly within {timeout_seconds}s")


def wait_for_ready(state: dict[str, Any], timeout_seconds: int = START_TIMEOUT_SECONDS) -> None:
    if skip_docker():
        return
    expected = expected_deployment(state)
    container_name = str(state.get("container_name", expected["container_name"]))
    endpoint = str(state.get("endpoint", expected["endpoint"]))
    port = int(state.get("port", expected["port"]))
    expected_model = str(state.get("served_model_name", expected["served_model_name"]))
    deadline = time.monotonic() + timeout_seconds
    last_status = "unknown"
    while time.monotonic() < deadline:
        live_status, health = container_status(container_name)
        health = health or "none"
        listeners = port_lines_for(port)
        port_state = "listening" if listeners else "not_listening"
        endpoint_ok = endpoint_models_ok(endpoint, expected_model)
        last_status = (
            f"container={live_status} health={health} "
            f"port_{port}={port_state} models={'ok' if endpoint_ok else 'not_ok'}"
        )
        print(f"startup_status: {last_status}", flush=True)
        if live_status in {"exited", "dead"}:
            raise LlmctlError(f"container exited during startup: {last_status}")
        if health == "unhealthy":
            raise LlmctlError(f"container health became unhealthy during startup: {last_status}")
        if (
            live_status == "running"
            and health in {"healthy", "none", ""}
            and localhost_bind_ok(listeners, port)
            and endpoint_ok
        ):
            return
        time.sleep(5)
    raise LlmctlError(
        f"endpoint was not ready within {timeout_seconds}s; last status {last_status}"
    )


def plan_lifecycle(command: str, state: dict[str, Any]) -> None:
    expected = expected_deployment(state)
    compose_file = Path(str(state.get("compose_file") or expected["compose_file"]))
    compose_profile = state_compose_profile(state)
    profile_args = f" --profile {compose_profile}" if compose_profile else ""
    container_name = state.get("container_name", expected["container_name"])
    port = int(state.get("port", expected["port"]))
    container_port = int(expected["container_port"])
    print(f"DRY-RUN: would {command} {expected['label']}")
    print(f"model_profile: {state.get('model_profile', expected['model_profile'])}")
    print(f"runtime_profile: {state.get('runtime_profile', expected['runtime_profile'])}")
    print(f"container_name: {container_name}")
    print(f"compose_file: {compose_file}")
    print(f"endpoint: {state.get('endpoint', expected['endpoint'])}")
    print(f"host_bind: 127.0.0.1:{port}")
    if command == "start":
        print(f"start_command: sudo -n docker compose -f {compose_file}{profile_args} up -d")
        print("state_update: status=active started_at=<timestamp>")
        print("wait_for_readiness: yes by default; pass --no-wait to skip")
    elif command == "stop":
        print(f"stop_command: sudo -n docker compose -f {compose_file}{profile_args} stop")
        print("state_update: status=stopped stopped_at=<timestamp>")
    elif command == "restart":
        if state.get("model_profile") == REAL_MODEL_PROFILE:
            print("restart_yes_supported: false")
            print("restart_yes_result: STOP: restart --yes is unsupported for the real model until a dedicated lifecycle milestone approves it")
        else:
            print(f"restart_stop_command: sudo -n docker compose -f {compose_file}{profile_args} stop")
            print(f"restart_start_command: sudo -n docker compose -f {compose_file}{profile_args} up -d")
            print("state_update: status=active restarted_at=<timestamp>")
    elif command == "deactivate":
        print(f"deactivate_command: sudo -n docker compose -f {compose_file}{profile_args} down")
        print(f"archive_target: {ACTIVE_HISTORY_ROOT}/active-YYYYMMDD-HHMMSS.json")
        print("state_update: active.json moved to history")
    print(f"container_internal_port: {container_port}")
    print("model_file_deletion: none")
    print("image_deletion: none")
    print("docker_prune: never")


def cmd_start(args: argparse.Namespace) -> int:
    _, state = state_for_start()
    if args.dry_run:
        plan_lifecycle("start", state)
        return 0
    if not require_yes(args, "start"):
        return 2
    compose_file = ensure_lifecycle_preflight(state, require_gpu=True, check_port=True)
    ensure_model_files_exist(state)
    if not skip_docker():
        run_passthrough(compose_cmd(compose_file, "up", "-d", profile=state_compose_profile(state)))
        if args.no_wait:
            print("INFO: readiness wait skipped by --no-wait")
        else:
            wait_for_ready(state)
    updated = update_active_state(state, status="active", started_at=utc_timestamp())
    print("PASS: deployment started")
    return print_active_state(ACTIVE_FILE, updated)


def cmd_stop(args: argparse.Namespace) -> int:
    _, state = require_active_state()
    if args.dry_run:
        plan_lifecycle("stop", state)
        return 0
    if not require_yes(args, "stop"):
        return 2
    compose_file = ensure_lifecycle_preflight(state, require_gpu=False, check_port=False)
    if not skip_docker():
        run_passthrough(compose_cmd(compose_file, "stop", profile=state_compose_profile(state)))
        wait_for_stopped(str(state.get("container_name", SMOKE_CONTAINER_NAME)), int(state.get("port", SMOKE_PORT)))
    updated = update_active_state(state, status="stopped", stopped_at=utc_timestamp())
    print("PASS: deployment stopped")
    return print_active_state(ACTIVE_FILE, updated)


def cmd_restart(args: argparse.Namespace) -> int:
    _, state = require_active_state()
    if args.dry_run:
        plan_lifecycle("restart", state)
        return 0
    if not require_yes(args, "restart"):
        return 2
    if state.get("model_profile") == REAL_MODEL_PROFILE:
        eprint(
            "STOP: restart --yes is unsupported for the real model until "
            "a dedicated lifecycle milestone approves it; use stop --yes only "
            "if a human explicitly wants to stop it"
        )
        return 2
    compose_file = ensure_lifecycle_preflight(state, require_gpu=True, check_port=False)
    if not skip_docker():
        run_passthrough(compose_cmd(compose_file, "stop", profile=state_compose_profile(state)))
        wait_for_stopped(str(state.get("container_name", SMOKE_CONTAINER_NAME)), int(state.get("port", SMOKE_PORT)))
        run_passthrough(compose_cmd(compose_file, "up", "-d", profile=state_compose_profile(state)))
        wait_for_ready(state)
    updated = update_active_state(state, status="active", restarted_at=utc_timestamp())
    print("PASS: deployment restarted")
    return print_active_state(ACTIVE_FILE, updated)


def cmd_deactivate(args: argparse.Namespace) -> int:
    state_file, state = require_active_state()
    if args.dry_run:
        plan_lifecycle("deactivate", state)
        return 0
    if not require_yes(args, "deactivate"):
        return 2
    compose_file = ensure_lifecycle_preflight(state, require_gpu=False, check_port=False)
    if not skip_docker():
        run_passthrough(compose_cmd(compose_file, "down", profile=state_compose_profile(state)))
        wait_for_stopped(str(state.get("container_name", SMOKE_CONTAINER_NAME)), int(state.get("port", SMOKE_PORT)))
    ACTIVE_HISTORY_ROOT.mkdir(parents=True, exist_ok=True)
    archive = ACTIVE_HISTORY_ROOT / f"active-{compact_timestamp()}.json"
    state_file.replace(archive)
    print("PASS: deployment deactivated")
    print(f"archived_active_state: {archive}")
    print("active: none")
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    active = load_active_state()
    if args.dry_run:
        print("DRY-RUN: would inspect manager/runtime logs")
        print(f"logs_root: {LOGS_ROOT}")
        if active is not None:
            _, state = active
            container_name = state.get("container_name", "unknown")
            print(f"container_name: {container_name}")
            print(f"log_command: sudo -n docker logs --tail {args.tail} {container_name}")
        else:
            print("active: none")
        print("no log files were read")
        return 0
    if not args.yes:
        eprint("STOP: logs output requires --yes or use --dry-run")
        eprint("dry_run_command: scripts/llmctl logs --dry-run")
        return 2
    if active is None:
        raise LlmctlError("active state missing; no active container logs to inspect")
    _, state = active
    validate_supported_state(state)
    container_name = str(state.get("container_name", SMOKE_CONTAINER_NAME))
    if skip_docker():
        print("SKIP: docker logs skipped for fixture mode")
        return 0
    run_passthrough(docker_cmd("logs", "--tail", str(args.tail), container_name))
    return 0


def cmd_plan_download(args: argparse.Namespace) -> int:
    models, _, errors = validate_all()
    if errors:
        for error in errors:
            eprint(f"FAIL: {error}")
        return 1
    if args.model_profile not in models:
        eprint(f"FAIL: unknown model profile: {args.model_profile}")
        return 1
    model = models[args.model_profile]
    if not model.get("allowed_first_download"):
        eprint(
            "STOP: this profile is not approved for first download; human approval "
            "is required"
        )
        return 2
    host_checks("download")
    print("PLAN: download model profile")
    print(f"model_profile: {args.model_profile}")
    print(f"hf_repo: {model.get('hf_repo')}")
    print(f"target_root: {MODELS_ROOT}")
    print(f"hf_cache_root: {HF_CACHE_ROOT}")
    print("download_performed: false")
    print("real_download: reserved_for_M8_or_later")
    return 0


def cmd_env(_args: argparse.Namespace) -> int:
    print(f"CONFIG_ROOT={CONFIG_ROOT}")
    print(f"DATA_ROOT={DATA_ROOT}")
    print(f"MODELS_ROOT={MODELS_ROOT}")
    print(f"HF_HOME={HF_CACHE_ROOT}")
    print(f"HF_HUB_CACHE={HF_CACHE_ROOT / 'hub'}")
    print(f"TRANSFORMERS_CACHE={HF_CACHE_ROOT / 'transformers'}")
    print(f"LOGS_ROOT={LOGS_ROOT}")
    print(f"BUILD_ROOT={BUILD_ROOT}")
    print(f"STATE_ROOT={STATE_ROOT}")
    print(f"ACTIVE_ROOT={ACTIVE_ROOT}")
    print(f"SECRET_ROOT={SECRET_ROOT}")
    print("SECRET_VALUES=not_read")
    return 0


def unsupported_real_command(command: str) -> int:
    eprint(
        f"STOP: {command} is reserved for later milestones; use plan-* or lifecycle "
        "commands for the existing smoke deployment"
    )
    return 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="llmctl",
        description="Validate profiles and manage the active localhost-only SGLang lifecycle.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("doctor").set_defaults(func=cmd_doctor)
    subparsers.add_parser("list-models").set_defaults(func=cmd_list_models)
    subparsers.add_parser("list-runtimes").set_defaults(func=cmd_list_runtimes)
    subparsers.add_parser("validate").set_defaults(func=cmd_validate)
    subparsers.add_parser("active").set_defaults(func=cmd_active)
    subparsers.add_parser("status").set_defaults(func=cmd_status)
    subparsers.add_parser("env").set_defaults(func=cmd_env)

    show_model = subparsers.add_parser("show-model")
    show_model.add_argument("name")
    show_model.set_defaults(func=cmd_show_model)

    show_runtime = subparsers.add_parser("show-runtime")
    show_runtime.add_argument("name")
    show_runtime.set_defaults(func=cmd_show_runtime)

    plan_activate = subparsers.add_parser("plan-activate")
    plan_activate.add_argument("model_profile")
    plan_activate.add_argument("--runtime", required=True)
    plan_activate.set_defaults(func=cmd_plan_activate)

    activate = subparsers.add_parser("activate")
    activate.add_argument("model_profile")
    activate.add_argument("--runtime", required=True)
    activate.add_argument("--dry-run", action="store_true")
    activate.set_defaults(func=cmd_activate)

    deactivate = subparsers.add_parser("deactivate")
    deactivate.add_argument("--dry-run", action="store_true")
    deactivate.add_argument("--yes", action="store_true")
    deactivate.set_defaults(func=cmd_deactivate)

    logs = subparsers.add_parser("logs")
    logs.add_argument("--dry-run", action="store_true")
    logs.add_argument("--yes", action="store_true")
    logs.add_argument("--tail", type=int, default=200)
    logs.set_defaults(func=cmd_logs)

    start = subparsers.add_parser("start")
    start.add_argument("--dry-run", action="store_true")
    start.add_argument("--yes", action="store_true")
    start.add_argument(
        "--no-wait",
        action="store_true",
        help="start the container but skip the default readiness wait",
    )
    start.set_defaults(func=cmd_start)

    stop = subparsers.add_parser("stop")
    stop.add_argument("--dry-run", action="store_true")
    stop.add_argument("--yes", action="store_true")
    stop.set_defaults(func=cmd_stop)

    restart = subparsers.add_parser("restart")
    restart.add_argument("--dry-run", action="store_true")
    restart.add_argument("--yes", action="store_true")
    restart.set_defaults(func=cmd_restart)

    plan_download = subparsers.add_parser("plan-download")
    plan_download.add_argument("model_profile")
    plan_download.set_defaults(func=cmd_plan_download)

    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if argv and argv[0] in {"download"}:
        return unsupported_real_command(argv[0])
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except subprocess.CalledProcessError as exc:
        eprint(f"FAIL: required check failed: {' '.join(map(str, exc.cmd))}")
        return exc.returncode or 1
    except LlmctlError as exc:
        eprint(f"FAIL: {exc}")
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
